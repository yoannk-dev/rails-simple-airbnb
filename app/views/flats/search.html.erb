<div class="container py-4">
  <h1>All our Flats</h1>
  <span class="d-block mb-4 text-danger">All <%= @flats.length %> flats</span>

  <div class="row">
    <% @flats.each do |flat| %>

      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
        <div class="card mb-4">
          <div class="card-image">
            <img src="<%= flat.picture_url %>" class="card-img-top" alt="..." />
          </div>
          <div class="card-body">
            <h5 class="card-title"><%= flat.name %></h5>
            <p class="card-text"><%= flat.address %></p>
            <div class="d-flex align-items-center gap-2">
              <i class="fa-solid fa-users text-danger"></i>
              <%= flat.number_of_guests %>
              <i class="fa-solid fa-dollar-sign text-danger"></i>
              <%= flat.price_per_night %>€
            </div>
          </div>
          <div class="card-body border-top d-flex gap-3">
            <%= link_to "More info", flat_path(flat) %>
            <%= link_to "Edit", edit_flat_path(flat) %>
            <%= link_to "Delete",
              flat_path(flat),
              data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}
            %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
